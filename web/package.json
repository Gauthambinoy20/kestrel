{
  "name": "kestrel-web",
  "version": "0.1.0",
  "description": "Kestrel dashboard — a world-class UI over the discovery engine's ranked output.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
