# Kestrel — environment configuration.
# Copy to `.env` and fill in. ALL keys are OPTIONAL: the keyless public ATS
# boards (Greenhouse, Lever, Ashby, RemoteOK) run with no credentials at all.
# API-key sources simply switch on when their keys are present.

# --- Optional job-aggregator API keys (sources activate only when set) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_KEY=
SERPAPI_KEY=
SCRAPEGRAPHAI_KEY=

# --- Scrape stage tuning (safe defaults shown) ---
SOURCE_CONCURRENCY=8
SOURCE_RETRIES=2
SOURCE_TIMEOUT_MS=30000
# Cap public ATS boards checked per source (0 = all). Useful for local/dev runs.
MAX_COMPANY_BOARDS_PER_SOURCE=0

# --- Link-verify stage tuning ---
VERIFY_CONCURRENCY=6
VERIFY_RETRIES=2
VERIFY_TIMEOUT_MS=15000
VERIFY_COMPANY_LINKS=true
COMPANY_LINK_VERIFY_LIMIT=60

# --- Telegram digest (optional; only needed for the Telegram adapter) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
